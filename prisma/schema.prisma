generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model groups {
  id          String   @id
  name        String
  description String?
  color       String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  users       users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits      habits[]
  tasks       tasks[]

  @@index([userId])
}

model habit_labels {
  habitId String
  labelId String
  habits  habits @relation(fields: [habitId], references: [id], onDelete: Cascade)
  labels  labels @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([habitId, labelId])
}

model habit_logs {
  id        String   @id
  habitId   String
  date      DateTime @db.Date
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime
  habits    habits   @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([date])
  @@index([habitId])
}

model habits {
  id           String         @id
  title        String
  description  String?
  type         HabitType      @default(DAILY)
  targetCount  Int
  importance   Int            @default(50)
  endDate      DateTime?
  userId       String
  groupId      String?
  parentTaskId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  activeDays   Int[]          @default([])
  habit_labels habit_labels[]
  habit_logs   habit_logs[]
  groups       groups?        @relation(fields: [groupId], references: [id])
  tasks        tasks?         @relation(fields: [parentTaskId], references: [id], onDelete: Cascade)
  users        users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([parentTaskId])
  @@index([userId])
}

model labels {
  id           String         @id
  name         String
  color        String?
  userId       String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  habit_labels habit_labels[]
  users        users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task_labels  task_labels[]

  @@index([userId])
}

model sessions {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model task_labels {
  taskId  String
  labelId String
  labels  labels @relation(fields: [labelId], references: [id], onDelete: Cascade)
  tasks   tasks  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model tasks {
  id                String        @id
  title             String
  description       String?
  importance        Int           @default(50)
  progress          Float?        @default(0)
  total_weight      BigInt?
  weighted_progress BigInt?
  deadline          DateTime?
  groupId           String?
  parentId          String?
  userId            String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  habits            habits[]
  task_labels       task_labels[]
  groups            groups?       @relation(fields: [groupId], references: [id])
  tasks             tasks?        @relation("tasksTotasks", fields: [parentId], references: [id], onDelete: Cascade)
  other_tasks       tasks[]       @relation("tasksTotasks")
  users             users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deadline])
  @@index([groupId])
  @@index([parentId])
  @@index([userId])
}

model users {
  id            String     @id
  email         String     @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  accounts      accounts[]
  groups        groups[]
  habits        habits[]
  labels        labels[]
  sessions      sessions[]
  tasks         tasks[]
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum HabitType {
  DAILY
  WEEKLY
  MONTHLY
}
