# Database
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/progress_db?schema=public"

# NextAuth.js
# The URL of your application (use http://localhost:3000 for local development)
NEXTAUTH_URL="http://localhost:3000"
# Secret key for NextAuth.js (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=""

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
